    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\n// 1. Ordenar por fecha (más reciente primero)\nitems.sort((a, b) => b.json.fecha_creacion - a.json.fecha_creacion);\n\n// 2. Agrupar por tipo\nconst grupos = {};\n\nfor (const item of items) {\n  const tipo = item.json.tipo || \"Sin tipo\";\n\n  if (!grupos[tipo]) {\n    grupos[tipo] = [];\n  }\n\n  grupos[tipo].push(item.json);\n}\n\n// 3. Construir mensaje\nlet mensajeFinal = `Tickets:\\n`;\n\nfor (const tipo in grupos) {\n  mensajeFinal += `\\n=== Tipo: ${tipo} ===\\n`;\n\n  for (const data of grupos[tipo]) {\n    mensajeFinal += `\nID: ${data.id_ticket}\nTipo: ${data.tipo}\nPrioridad: ${data.prioridad}\nDescripción: ${data.descripcion}\nEstado: ${data.estado}\nCreado por: ${data.creado_por}\nFecha de creación: ${data.fecha_creacion}\n-------------------------\\n`;\n  }\n}\n\n// 4. Retornar un solo item con el mensaje\nreturn [\n  {\n    json: {\n      mensaje: mensajeFinal\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
